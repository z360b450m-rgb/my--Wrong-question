{
  "name": "cuotiben",
  "version": "2.0.0",
  "private": true,
  "description": "智能错题管理工具 - 记录错题、对比答案、高效复习",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron": "vite build && electron .",
    "electron:dev": "vite build --watch & sleep 3 && electron .",
    "build:win": "vite build && electron-builder --win portable",
    "build:win:installer": "vite build && electron-builder --win nsis",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "build:all": "vite build && electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.cuotiben.app",
    "productName": "错题本",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["zh_CN", "en_US"],
      "shortcutName": "错题本"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon-512.png",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/icon-512.png",
      "category": "Education"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "electron": "latest",
    "electron-builder": "latest",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  },
  "dependencies": {
    "marked": "^15.0.0",
    "vue": "^3.5.0"
  }
}
